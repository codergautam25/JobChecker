# Ollama Local Service Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ChromaDB Config
CHROMADB_HOST=localhost
CHROMADB_PORT=8000
CHROMADB_PERSIST_DIRECTORY=./chromadb_storage

# SQLite DB Path
SQLITE_DB_PATH=./jobchecker.db

# Gmail Daemon Credentials
# Note: GMAIL_APP_PASSWORD requires generating a 16-character App Password via Google Account Security
GMAIL_EMAIL=your_email@gmail.com
GMAIL_APP_PASSWORD=your_app_password

# Playwright Browser Config
PLAYWRIGHT_USER_DATA_DIR=./.playwright_session
PLAYWRIGHT_HEADLESS=false

# LLM Provider Configuration (Ollama Local or OpenAI compatible)
OPENAI_API_KEY=ollama
OPENAI_API_BASE=http://localhost:11434/v1
LLM_MODEL=llama3.2:3b

# Background Daemon Interval
EMAIL_POLL_INTERVAL_SECONDS=300
UI_CACHE_TTL_SECONDS=60
